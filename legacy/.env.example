# Supabase — auth (Google login) + RLS data (settings, history, clients).
# Without these the app runs open (no login gate).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — platform fallback key. Users can set their own key in Settings;
# set REQUIRE_OWN_KEYS=1 to force every user to use their own.
ANTHROPIC_API_KEY=
REQUIRE_OWN_KEYS=

# Apify — optional. When set, the Social Analyzer pulls Instagram profile + posts
# automatically from a handle; without it, the user adds a screenshot.
APIFY_TOKEN=

# Cloudflare — publish generated websites to a live URL (Workers).
# Token needs the "Workers Scripts: Edit" permission. Enable workers.dev for the
# account so sites get a <name>.<account>.workers.dev URL.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# The account's workers.dev subdomain (Workers & Pages -> Account Details ->
# Subdomain), e.g. geral-933 -> sites live at <name>.geral-933.workers.dev.
CLOUDFLARE_WORKERS_SUBDOMAIN=
