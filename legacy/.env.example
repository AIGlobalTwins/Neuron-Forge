# Supabase — auth (Google login) + RLS data (settings, history, clients).
# Without these the app runs open (no login gate).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — platform fallback key. Users can set their own key in Settings;
# set REQUIRE_OWN_KEYS=1 to force every user to use their own.
ANTHROPIC_API_KEY=
REQUIRE_OWN_KEYS=

# Apify — optional. When set, the Social Analyzer pulls Instagram profile + posts
# automatically from a handle; without it, the user adds a screenshot.
APIFY_TOKEN=

# Vercel — optional, for one-click deploy of generated sites.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
